# Copy to .env beside the compose file and fill in values for your setup.
#
# Docker Compose reads this file automatically for ${VAR} interpolation and as
# the container env_file, so the same .env drives both the host bind mounts and
# the in-container runtime config — no `set -a; source` step needed.
#
# Bind mounts are identity-mapped (host path == in-container path), so the
# runtime paths below must fall inside the host directories in the first block.

# ── Compose host bind paths ─────────────────────────────────────────────────
# Host directories bind-mounted into the container. Defaults live in the compose
# file (/data/...); set these to your real host paths.

# Host dir holding linearcast.db and state. Mounted read-write.
LINEARCAST_DATA_DIR=/data/linearcast

# Host dir for the packager output cache. Mounted read-write.
LINEARCAST_CACHE_DIR=/data/linearcast/cache

# Media library root. Mounted read-only.
LINEARCAST_MEDIA_ROOT=/data/media

# Public nginx/web UI port published by the compose file.
# WEB_UI_PORT=8080

# ── Required: runtime config ────────────────────────────────────────────────
# Read by the linearcast binaries inside the container. Because mounts are
# identity-mapped, these must sit inside the host dirs above.

# Path to linearcast.db (inside LINEARCAST_DATA_DIR).
LINEARCAST_DB=/data/linearcast/linearcast.db

# Package cache (inside LINEARCAST_CACHE_DIR).
CACHE_DIR=/data/linearcast/cache

# Address the linearcast HLS server binds to inside the container. The host
# port is served by nginx/web UI via WEB_UI_PORT.
LINEARCAST_ADDR=:8888

# Admin password — required to start linearcast-admin.
# Playback, channel list, and HLS endpoints stay public.
LINEARCAST_ADMIN_PASSWORD=REPLACE_WITH_A_UNIQUE_ADMIN_PASSWORD

# Timezone for the running processes.
TZ=America/New_York

# ── Optional: registry image deploy ─────────────────────────────────────────
# Required for deploy/docker-compose.image.yml (pull the published image instead
# of building locally). Prefer an immutable version tag over :latest.
# LINEARCAST_IMAGE=ghcr.io/tckrcr/linearcast:latest

# ── Optional: admin security ──────────────────────────────────────────────────
# Set true only when browsers reach /admin over HTTPS. Keep unset for HTTP.
# LINEARCAST_ADMIN_COOKIE_SECURE=false
# Development/recovery only — starts admin without auth when no password is set.
# LINEARCAST_ADMIN_ALLOW_NO_AUTH=true

# ── Optional: media server integration ───────────────────────────────────────
# PLEX_URL and PLEX_PATH_MAP are read by linearcast-admin (DB takes precedence
# once saved via Admin > Tools). The admin binary stores and manages its token
# in the database.
# JELLYFIN_URL and JELLYFIN_PATH_MAP are admin-only; DB takes precedence once
# saved via Admin > Tools.
# PLEX_URL=http://plex.local:32400
# PLEX_PATH_MAP=/media/tv=/data/media/tv
# JELLYFIN_URL=http://jellyfin.local:8096
# JELLYFIN_PATH_MAP=/media=/data/media


